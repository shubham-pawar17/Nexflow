
generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}
model User { 
  id    Int     @id @default(autoincrement()) 
  email String  @unique
  name  String?
  post Post[]
} 
model Post { 
  id    Int     @id @default(autoincrement()) 
  title String
  content  String?
  authorId Int
  author User  @relation(fields: [authorId] , references: [id])
} 
